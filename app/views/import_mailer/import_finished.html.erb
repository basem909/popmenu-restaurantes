<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Import Finished</title>
  </head>
  <body style="margin:0; padding:0; background:#f6f7fb; font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif; color:#111;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background:#f6f7fb; padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="640" style="background:#ffffff; border-radius:8px; box-shadow:0 1px 3px rgba(0,0,0,.06); overflow:hidden;">
            <tr>
              <td style="padding:24px 24px 8px 24px;">
                <h1 style="margin:0; font-size:20px; line-height:1.3;">Import completed</h1>
                <p style="margin:8px 0 0 0; font-size:14px; color:#555;">
                  Hello <strong><%= @user.email %></strong>,
                </p>
                <p style="margin:6px 0 0 0; font-size:14px; color:#555;">
                  Your restaurant data import has finished. Here’s a quick summary:
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:0 24px 16px 24px;">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="border-collapse:collapse;">
                  <tr>
                    <td style="padding:12px 16px; border:1px solid #eaecef; border-right:none; border-radius:6px 0 0 0; background:#fafbff; width:33%;">
                      <div style="font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:.02em;">Restaurants</div>
                      <div style="margin-top:6px; font-size:14px; color:#111;">
                        created <strong><%= @result.restaurants_created %></strong>,
                        found <strong><%= @result.restaurants_found %></strong>
                      </div>
                    </td>
                    <td style="padding:12px 16px; border:1px solid #eaecef; border-right:none; background:#fafbff; width:33%;">
                      <div style="font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:.02em;">Menus</div>
                      <div style="margin-top:6px; font-size:14px; color:#111;">
                        created <strong><%= @result.menus_created %></strong>,
                        found <strong><%= @result.menus_found %></strong>
                      </div>
                    </td>
                    <td style="padding:12px 16px; border:1px solid #eaecef; border-radius:0 6px 0 0; background:#fafbff; width:34%;">
                      <div style="font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:.02em;">Items</div>
                      <div style="margin-top:6px; font-size:14px; color:#111;">
                        created <strong><%= @result.items_created %></strong>,
                        found <strong><%= @result.items_found %></strong>
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td colspan="3" style="padding:12px 16px; border:1px solid #eaecef; border-top:none; border-radius:0 0 6px 6px; background:#fff;">
                      <div style="font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:.02em;">Links (Menu ↔ Item)</div>
                      <div style="margin-top:6px; font-size:14px; color:#111;">
                        created <strong><%= @result.links_created %></strong>,
                        updated <strong><%= @result.links_updated %></strong>,
                        unchanged <strong><%= @result.links_unchanged %></strong>
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:8px 24px 24px 24px;">
                <% if @result.errors.present? %>
                  <div style="padding:12px 16px; background:#fff7ed; border:1px solid #fed7aa; border-radius:6px; color:#9a3412;">
                    <strong>Errors encountered</strong>
                    <ul style="margin:8px 0 0 18px; padding:0; font-size:13px;">
                      <% @result.errors.each do |err| %>
                        <li><%= err %></li>
                      <% end %>
                    </ul>
                  </div>
                <% else %>
                  <div style="padding:12px 16px; background:#ecfdf5; border:1px solid #a7f3d0; border-radius:6px; color:#065f46; font-size:14px;">
                    ✅ No errors were reported.
                  </div>
                <% end %>
              </td>
            </tr>

            <tr>
              <td style="padding:0 24px 24px 24px; color:#6b7280; font-size:12px;">
                If you didn’t request this import, please contact support.
              </td>
            </tr>
          </table>

          <div style="margin-top:12px; color:#9ca3af; font-size:12px;">
            © <%= Time.zone.now.year %> Your App
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>
